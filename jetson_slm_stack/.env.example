# =============================================================
# Jetson SLM Stack - 환경 설정 파일
# 이 파일을 수정해서 모델 동작 파라미터를 자유롭게 조정하세요.
# =============================================================

# ── Docker / Base Image ──────────────────────────────────────
BASE_IMAGE=nvcr.io/nvidia/pytorch:24.12-py3-igpu
DOCKERFILE_PATH=docker/Dockerfile.jetson

# ── HuggingFace ──────────────────────────────────────────────
HF_TOKEN=your_hf_token_here
LLAMA_MODEL_ID=meta-llama/Llama-3.2-1B-Instruct
DEEPSEEK_MODEL_ID=deepseek-ai/DeepSeek-R1-Distill-Qwen-1.5B
QWEN_MODEL_ID=Qwen/Qwen2.5-1.5B-Instruct

# ── 디바이스 / 정밀도 ─────────────────────────────────────────
# DEVICE: cuda | cpu
# ※ 이 데스크탑에서는 nvcr.io/nvidia/pytorch:24.12-py3-igpu (Jetson 이미지)의
#   CUDA 컨텍스트 초기화가 unified memory(CPU RAM)에서 ~1.8 GB를 선점해버려
#   모델 로드할 RAM이 부족해집니다. DEVICE=cpu로 설정하면 CUDA 컨텍스트를
#   건너뛰어 가용 RAM이 ~3.8 GB 확보됩니다.
#   실제 Jetson 보드에서 실행할 때는 DEVICE=cuda로 되돌리세요.
DEVICE=cuda
# DTYPE: float16 | float32 | bfloat16
# ※ 이 값은 모델 '저장(storage)' 포맷 기준입니다.
#   float16 → 2.5 GB RAM (CPU에서도 저장 가능, 샘플링은 float32로 업캐스트)
#   float32 → 5.0 GB RAM (CPU에서 OOM 가능)
DTYPE=float16
# LOAD_IN_4BIT: 4-bit 양자화 여부
#   0 = 비활성화 (기본) — float16 로드, ~2.4 GB VRAM, 정확도 높음
#   1 = 활성화          — 4-bit 로드,  ~0.6 GB VRAM, 정확도 소폭 하락, CUDA 필수
#   Jetson Orin iGPU(sm_87)에서는 bitsandbytes CUDA 커널 미지원 → 반드시 0으로 설정
LOAD_IN_4BIT=0

# GPU_OFFLOAD_ENABLED: 전체 GPU 적재 대신 하이브리드 offload 로드 사용 여부
#   1 = 사용. Jetson처럼 VRAM이 빡빡한 환경에서 권장
#   0 = 비활성화. 일반 CUDA 로드만 시도
GPU_OFFLOAD_ENABLED=1
# GPU_TARGET_MEMORY_MB: GPU에 올리고 싶은 목표 메모리 예산(MiB)
#   safe_ops CUDA 프로브가 이 값을 상한으로 보고 실제 할당 가능한 값까지 낮춰 잡음
#   너무 크게 잡으면 allocator assert / nvmap 에러가 날 수 있음
GPU_TARGET_MEMORY_MB=640
# GPU_MEMORY_RESERVE_MB: CUDA 컨텍스트, KV cache, 런타임 여유분으로 남겨둘 메모리(MiB)
#   예산 계산 시 free memory에서 먼저 제외됨
#   값이 작을수록 공격적이고, 값이 클수록 안전하지만 GPU 활용은 줄어듦
GPU_MEMORY_RESERVE_MB=512
# GPU_OFFLOAD_BUFFERS: transformers offload 버퍼 유지 여부
#   0 = 버퍼 최소화, 메모리 절약 우선
#   1 = 버퍼 유지, 일부 환경에서 성능은 나아질 수 있으나 메모리 사용 증가
GPU_OFFLOAD_BUFFERS=0
# GPU_PROBE_STEP_MB: safe_ops CUDA budget 탐색 시 줄여가는 단위(MiB)
#   작을수록 더 세밀하지만 로딩 전 탐색 시간이 조금 늘어남
GPU_PROBE_STEP_MB=64
# GPU_PROBE_MIN_MB: 이 값보다 작은 GPU 예산이면 offload 로드를 포기
#   너무 낮추면 GPU를 쓰더라도 이득이 거의 없을 수 있음
GPU_PROBE_MIN_MB=256

# ── 토큰 한도 ─────────────────────────────────────────────────
# MAX_INPUT_TOKENS: 입력 프롬프트 최대 토큰 수
#   질문 본문뿐 아니라 system prompt, chat template 등 모델이 먼저 읽는 토큰까지 포함해서 생각해야 함
#   값이 커질수록 긴 문맥을 넣을 수 있지만, latency와 메모리 사용량도 같이 증가
#   512  → 빠른 테스트 / 짧은 질문
#   1024 → 일반 사용
#   2048 → 문서 요약 / 긴 컨텍스트
MAX_INPUT_TOKENS=512

# MAX_NEW_TOKENS: 응답 최대 토큰 수 (길수록 응답이 길어지지만 느려짐)
#   "몇 글자"가 아니라 모델이 새로 생성할 최대 token 수를 뜻함
#   전체 context는 대략 input tokens + new tokens 로 이해하면 됨
#   예: MAX_INPUT_TOKENS=512, MAX_NEW_TOKENS=32 이면 한 요청에서 최대 약 544 tokens 범위를 사용
#   값을 줄이면 짧고 빠르며 안정적인 smoke test에 유리함
#   값을 늘이면 더 긴 답변이 가능하지만 Jetson에서는 KV cache / latency / OOM 부담이 같이 증가
#   32   → smoke test, JSON 응답 확인, offload 안정성 확인
#   128  → 짧은 답변 / 속도 우선
#   256  → 균형
#   512  → 긴 설명 / 코드 생성
MAX_NEW_TOKENS=128

# ── 생성 파라미터 ─────────────────────────────────────────────
# TEMPERATURE: 0.0(결정적) ~ 1.0(창의적)
#   0.0  → 항상 같은 답 (사실 질문)
#   0.2  → 기본값
#   0.7  → 창의적 글쓰기
TEMPERATURE=0.0

# TOP_P: nucleus sampling (0~1), TEMPERATURE와 함께 작동
TOP_P=1.0

# TOP_K: 상위 K개 토큰 후보만 허용 (0=비활성)
TOP_K=0

# REPETITION_PENALTY: 반복 억제 (1.0=없음, 1.1~1.3 권장)
REPETITION_PENALTY=1.05

# ── 워밍업 / 메모리 ──────────────────────────────────────────
# ENABLE_WARMUP: 서버 시작 시 더미 추론으로 GPU 예열 (1=켜기)
ENABLE_WARMUP=0
# EMPTY_CACHE_ON_OOM: OOM 발생 시 캐시 비우고 재시도 (1=켜기)
EMPTY_CACHE_ON_OOM=1
# CPU_THREADS: CPU intra-op thread 수
#   CPU fallback 시 연산 병렬도에 직접 영향. 코어 수보다 과도하게 높이면 오히려 느려질 수 있음
CPU_THREADS=6
# CPU_INTEROP_THREADS: CPU inter-op thread 수
#   일반적으로 1 또는 2 권장. 높이면 thread contention이 생길 수 있음
CPU_INTEROP_THREADS=1
# GC_INTERVAL: 일반 요청 처리 중 강제 gc 주기
#   0 = 요청마다 강제 gc 하지 않음. 성능 우선
#   양수 = 해당 횟수마다 gc 수행
GC_INTERVAL=0
# CPU_FORCE_GREEDY: CPU fallback일 때 저온 샘플링을 greedy로 강제할지 여부
#   CPU half/bfloat16 경로에서 불필요한 sampling 비용과 불안정성을 줄이는 용도
CPU_FORCE_GREEDY=1
# CPU_FORCE_GREEDY_MAX_TEMP: 이 값 이하의 temperature면 CPU에서 greedy decode로 강제
#   예: 1.0 이면 대부분의 사실 질의가 greedy로 동작
CPU_FORCE_GREEDY_MAX_TEMP=1.0

# ── PyTorch 메모리 할당자 ────────────────────────────────────
# Jetson Unified Memory 최적화 — 변경 주의
# expandable_segments:True 는 Jetson nvmap 미지원 → NvMapMemAllocInternalTagged error 12 유발하므로 제거
PYTORCH_CUDA_ALLOC_CONF=max_split_size_mb:128,garbage_collection_threshold:0.8
