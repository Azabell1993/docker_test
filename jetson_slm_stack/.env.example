# =============================================================
# Jetson SLM Stack - 환경 설정 예시 파일
# 복사 후 .env로 저장하고 값을 수정하세요:
#   cp .env.example .env
# =============================================================

# ── Docker / Base Image ──────────────────────────────────────
BASE_IMAGE=nvcr.io/nvidia/pytorch:24.12-py3-igpu
DOCKERFILE_PATH=docker/Dockerfile.jetson

# ── HuggingFace ──────────────────────────────────────────────
HF_TOKEN=your_hf_token_here
LLAMA_MODEL_ID=meta-llama/Llama-3.2-1B-Instruct
DEEPSEEK_MODEL_ID=deepseek-ai/DeepSeek-R1-Distill-Qwen-1.5B

# ── 디바이스 / 정밀도 ─────────────────────────────────────────
# DEVICE: cuda | cpu
DEVICE=cuda
# DTYPE: float16 | float32 | bfloat16
DTYPE=float16
# LOAD_IN_4BIT: 1(활성화) | 0(비활성화) — VRAM 절약, 정확도 소폭 하락
LOAD_IN_4BIT=0

# ── 토큰 한도 ─────────────────────────────────────────────────
# MAX_INPUT_TOKENS: 입력 프롬프트 최대 토큰 수
#   512  → 빠른 테스트 / 짧은 질문
#   1024 → 일반 사용
#   2048 → 문서 요약 / 긴 컨텍스트
MAX_INPUT_TOKENS=512

# MAX_NEW_TOKENS: 응답 최대 토큰 수 (길수록 응답이 길어지지만 느려짐)
#   128  → 짧은 답변 / 속도 우선
#   256  → 균형
#   512  → 긴 설명 / 코드 생성
MAX_NEW_TOKENS=128

# ── 생성 파라미터 ─────────────────────────────────────────────
# TEMPERATURE: 0.0(결정적) ~ 1.0(창의적)
#   0.0  → 항상 같은 답 (사실 질문)
#   0.2  → 기본값
#   0.7  → 창의적 글쓰기
TEMPERATURE=0.2

# TOP_P: nucleus sampling (0~1)
TOP_P=0.9

# TOP_K: 상위 K개 토큰 후보만 허용 (0=비활성)
TOP_K=40

# REPETITION_PENALTY: 반복 억제 (1.0=없음, 1.1~1.3 권장)
REPETITION_PENALTY=1.05

# ── 워밍업 / 메모리 ──────────────────────────────────────────
ENABLE_WARMUP=1
EMPTY_CACHE_ON_OOM=1

# ── PyTorch 메모리 할당자 ────────────────────────────────────
PYTORCH_CUDA_ALLOC_CONF=max_split_size_mb:64,garbage_collection_threshold:0.8,expandable_segments:True
