# Jetson: set this to an NVIDIA Jetson-compatible base image tag that matches your L4T / JetPack release.
# Example pattern only: nvcr.io/nvidia/l4t-pytorch:<matching-tag>
BASE_IMAGE=nvcr.io/nvidia/l4t-pytorch:<MATCH_YOUR_L4T_TAG>
DOCKERFILE_PATH=docker/Dockerfile.jetson
HF_TOKEN=hf_xxx_replace_me
LLAMA_MODEL_ID=meta-llama/Llama-3.2-1B-Instruct
DEEPSEEK_MODEL_ID=deepseek-ai/DeepSeek-R1-Distill-Qwen-1.5B
DEVICE=cuda
DTYPE=float16
MAX_NEW_TOKENS=256
TEMPERATURE=0.2
TOP_P=0.9
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
